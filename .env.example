# Chaîne de connexion Postgres Neon (projet free tier).
# Récupérable dans le dashboard Neon > Connection Details > "Pooled connection".
# Copier ce fichier en .env.local (jamais commité) et renseigner la vraie valeur.
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
